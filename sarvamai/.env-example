# Sahayak AI Environment Variables (Example)
# Copy this file to .env and fill in your actual API keys
# DO NOT commit .env file to git - it contains secrets!

# ============================================================================
# REQUIRED FOR LOCAL TESTING (Agent + Knowledge Base)
# ============================================================================
# These are needed for the LangGraph agent to work with knowledge base search:

# HuggingFace API Key (for BAAI/bge-m3 embeddings)
# Get from: https://huggingface.co/settings/tokens
HF_TOKEN="hf_..."

# Qdrant Cloud (vector database with scheme documents)
# Get from: https://cloud.qdrant.io/
QDRANT_URL="https://xxxxx-xxxxx.region.cloud.qdrant.io"
QDRANT_API_KEY="your_qdrant_api_key_here"

# All 5 Gemini API Keys (round-robin load balancing)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY1="AIzaSy..."
GEMINI_API_KEY2="AIzaSy..."
GEMINI_API_KEY3="AIzaSy..."
GEMINI_API_KEY5="AIzaSy..."
GEMINI_API_KEY6="AIzaSy..."


# ============================================================================
# OPTIONAL FOR LOCAL TESTING (Agent can work without these initially)
# ============================================================================

# Twilio WhatsApp Integration (needed to receive/send WhatsApp messages)
# Get from: https://www.twilio.com/console
TWILIO_AUTH_TOKEN="your_twilio_auth_token_here"
TWILIO_ACCOUNT_SID="your_twilio_account_sid_here"
TWILIO_PHONE_NUMBER="+1234567890"  # Your Twilio WhatsApp number

# Google Serper (for web search fallback when KB doesn't have answer)
# Get free API key from: https://serper.dev
SERPER_API_KEY=""

# Sarvam AI (for STT, translation - optional, for voice notes)
# Get from: https://dashboard.sarvam.ai/
SARVAM_API_KEY="sk_..."

# ============================================================================
# DATABASE CONFIGURATION (Optional, for persistence)
# ============================================================================

# Supabase Postgres (for user sessions & message history)
# Get from: https://supabase.com/dashboard
# Without this: sessions stored in memory only (lost on restart)
POSTGRES_URL="postgresql://postgres:password@aws-region.pooler.supabase.com:5432/postgres"

# For LangGraph PostgreSQL checkpointer (future use)
SUPABASE_POSTGRES_URI="postgresql://postgres:password@aws-region.pooler.supabase.com:5432/postgres"

# ============================================================================
# LOGGING & DEBUG
# ============================================================================
LOG_LEVEL="INFO"  # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# RAG CONFIGURATION
# ============================================================================
RAG_CHUNK_SIZE=512
RAG_EMBED_MODEL="BAAI/bge-m3"
RAG_RETRIEVAL_TOP_K=5

# ============================================================================
# WEBHOOK SECURITY (Optional)
# ============================================================================
WHATSAPP_WEBHOOK_SECRET="your_webhook_secret_here"
