# Sahayak AI — Environment Variables
# Copy this file to .env and fill in your actual keys.
#
# ┌──────────────────────────────────────────────────────────────┐
# │ Service          │ Where to get it                          │
# ├──────────────────┼──────────────────────────────────────────┤
# │ Twilio           │ https://console.twilio.com               │
# │ Sarvam AI        │ https://dashboard.sarvam.ai              │
# │ Gemini (Google)  │ https://aistudio.google.com/app/apikey   │
# │ Qdrant Cloud     │ https://cloud.qdrant.io                  │
# │ Supabase         │ https://supabase.com/dashboard           │
# └──────────────────┴──────────────────────────────────────────┘

# ── Twilio (WhatsApp channel) ──
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_WHATSAPP_NUMBER=+14155238886

# ── Sarvam AI (STT + Translation) ──
SARVAM_API_KEY=your_sarvam_api_key

# ── Google Gemini (LLM — round-robin keys) ──
# Add up to 6 keys for automatic rotation on quota exhaustion.
GEMINI_API_KEY1=your_gemini_key_1
GEMINI_API_KEY2=your_gemini_key_2
GEMINI_API_KEY3=
GEMINI_API_KEY4=
GEMINI_API_KEY5=
GEMINI_API_KEY6=

# ── Qdrant Cloud (Vector DB) ──
QDRANT_URL=https://your-cluster-id.region.cloud.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key

# ── Supabase Postgres ──
POSTGRES_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ── RAG Settings ──
RAG_CHUNK_SIZE=512
RAG_EMBED_MODEL=sarvam-embed-v1
RAG_RETRIEVAL_TOP_K=5

# ── Logging ──
LOG_LEVEL=INFO
